filters:
  and:
    - file.inFolder("todo/tasks")
    - file.ext == "md"
properties:
  file.name:
    displayName: 唯一待办页
  status:
    displayName: 状态
  updated:
    displayName: 更新日期
views:
  - type: table
    name: 入口
    order:
      - file.name
      - status
      - updated
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 260
      note.status: 110
      note.updated: 120
